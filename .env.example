# ============================================================
# OSCA System - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# ============================================================

# --- App ---
APP_ENV=development           # development | production
APP_NAME="OSCA Management System"
APP_VERSION=2.0.0
DEBUG=true
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://osca.naap.edu.ph

# --- Security ---
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_64_output
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900    # 15 min
LOGIN_LOCKOUT_SECONDS=1800             # 30 min

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=osca_db
POSTGRES_USER=osca_user
POSTGRES_PASSWORD=OSCA_Init2024!
DATABASE_URL=postgresql+asyncpg://osca_user:OSCA_Init2024!@postgres:5432/osca_db

# --- Test Database (used by pytest; must be created manually — see README) ---
TEST_DATABASE_URL=postgresql+asyncpg://osca_user:OSCA_Init2024!@postgres:5432/osca_test

# --- pgvector ---
FACE_EMBEDDING_DIM=512
FACE_SIMILARITY_THRESHOLD=0.85        # Cosine similarity threshold

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@redis:6379/2

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET_FACES=osca-faces
MINIO_BUCKET_REPORTS=osca-reports
MINIO_SECURE=false                     # true in production with HTTPS

# --- Facial Recognition ---
FR_MODEL=insightface                   # insightface | deepface | face_recognition
FR_DETECTION_MODEL=retinaface_r50_v1
FR_RECOGNITION_MODEL=arcface_r100_v1
FR_GPU_ENABLED=false                   # Set true if NVIDIA GPU + CUDA available
FR_GPU_ID=0
FR_MAX_SCAN_TIME_SECONDS=3
FR_LIVENESS_ENABLED=true
FR_LIVENESS_THRESHOLD=0.6

# --- Email (Resend / SMTP) ---
EMAIL_PROVIDER=resend                  # resend | smtp
RESEND_API_KEY=CHANGE_ME_resend_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=osca@naap.edu.ph
SMTP_PASSWORD=CHANGE_ME_smtp_password
EMAIL_FROM=OSCA System <osca@naap.edu.ph>

# --- Celery ---
CELERY_TIMEZONE=Asia/Manila
OVERDUE_CHECK_SCHEDULE_HOURS=24       # How often to check overdue items

# --- Data Retention ---
FACE_IMAGE_RETENTION_DAYS=30          # R.A. 10173 compliance

# ============================================================
# PRODUCTION OVERRIDES (set in docker-compose.prod.yml)
# ============================================================
# DEBUG=false
# APP_ENV=production
# MINIO_SECURE=true
# FR_GPU_ENABLED=true
